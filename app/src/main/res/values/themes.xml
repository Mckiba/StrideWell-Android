<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Stridewell_Android" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen theme: holds the splash until MainActivity calls installSplashScreen() -->
    <style name="Theme.Stridewell_Android.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Stridewell_Android</item>
    </style>

</resources>
